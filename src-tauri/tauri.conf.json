{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ai-editor",
  "version": "0.1.0",
  "identifier": "com.local.aieditor",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ai-editor",
        "width": 1100,
        "height": 760,
        "minWidth": 760,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
